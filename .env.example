# Environment Variables for DaCaller

## Required (set in Vercel Dashboard)
# For Vercel deployment (uses SRV lookup):
# MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/dacaller?retryWrites=true&w=majority"

# For local dev if SRV DNS is blocked (pre-resolved hosts):
MONGODB_URI="your_mongodb_connection_string"

## Optional
VITE_API_URL=""  # Leave empty in production (uses relative /api/), set to http://localhost:3001 for local dev
